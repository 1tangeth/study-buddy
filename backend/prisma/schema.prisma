generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")

  documents      Document[]
  chatSessions   ChatSession[]
  quizAttempts   QuizAttempt[]
  studyPlans     StudyPlan[]
  topicMastery   TopicMastery[]
  calendarEvents CalendarEvent[]

  @@map("users")
}

model Document {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  filename    String
  text        String
  charCount   Int      @map("char_count")
  contentHash String?  @map("content_hash")
  createdAt   DateTime @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSessions  ChatSession[]
  quizAttempts  QuizAttempt[]
  planDocuments PlanDocument[]
  studyTopics   StudyTopic[]

  @@unique([userId, contentHash])
  @@map("documents")
}

// ── Study Planner ─────────────────────────────────────────────────────────

model StudyPlan {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  startDate   DateTime @map("start_date") @db.Date
  targetDate  DateTime @map("target_date") @db.Date
  hoursPerDay Float    @map("hours_per_day")
  daysOfWeek  Int[]    @map("days_of_week")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents PlanDocument[]
  blocks    ScheduledBlock[]

  @@map("study_plans")
}

model PlanDocument {
  planId     String @map("plan_id")
  documentId String @map("document_id")

  plan     StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([planId, documentId])
  @@map("plan_documents")
}

model StudyTopic {
  id               String   @id @default(uuid())
  documentId       String   @map("document_id")
  name             String
  estimatedMinutes Int      @map("estimated_minutes")
  difficulty       Int
  createdAt        DateTime @default(now()) @map("created_at")

  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  blocks   ScheduledBlock[]
  mastery  TopicMastery[]

  @@map("study_topics")
}

model ScheduledBlock {
  id              String   @id @default(uuid())
  planId          String   @map("plan_id")
  topicId         String   @map("topic_id")
  date            DateTime @map("date") @db.Date
  startTime       String   @map("start_time")
  durationMinutes Int      @map("duration_minutes")
  type            String
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")

  plan  StudyPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  topic StudyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@map("scheduled_blocks")
}

model TopicMastery {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  topicId     String   @map("topic_id")
  interval    Int      @default(1)
  easeFactor  Float    @default(2.5) @map("ease_factor")
  repetitions Int      @default(0)
  nextReview  DateTime @map("next_review") @db.Date
  lastScore   Int      @default(0) @map("last_score")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic StudyTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@map("topic_mastery")
}

model ChatSession {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  documentId String   @map("document_id")
  createdAt  DateTime @default(now()) @map("created_at")
  lastActive DateTime @default(now()) @map("last_active")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chat_sessions")
}

model Message {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  role      String
  content   String
  action    String?
  createdAt DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model QuizAttempt {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  documentId String   @map("document_id")
  score      Int
  total      Int
  language   String   @default("english")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model CalendarEvent {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  title           String   @default("Study")
  date            DateTime @db.Date
  startTime       String   @map("start_time")
  durationMinutes Int      @default(60) @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calendar_events")
}
